# Create .gitignore file
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
venv/
env/
ENV/
.venv/

# Flask
instance/
.webassets-cache

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Database files (if any)
*.db
*.sqlite

# Environment variables
.env
.flaskenv

# Logs
*.log
EOF